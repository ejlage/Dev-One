generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model aluno {
  idaluno             Int                  @id @default(autoincrement())
  utilizadoriduser    Int
  encarregadoiduser   Int?
  utilizador        utilizador          @relation(fields: [utilizadoriduser], references: [iduser], onDelete: NoAction, onUpdate: NoAction, map: "fkaluno173503")
  encarregadoeducacao encarregadoeducacao? @relation(fields: [encarregadoiduser], references: [utilizadoriduser], onDelete: NoAction, onUpdate: NoAction, map: "fkalunoencarregado")
  alunoaula          alunoaula[]
  alunogrupo         alunogrupo[]
}

model alunoaula {
  idalunoaula  Int   @id @default(autoincrement())
  alunoidaluno Int
  aulaidaula   Int
  aluno        aluno @relation(fields: [alunoidaluno], references: [idaluno], onDelete: NoAction, onUpdate: NoAction, map: "fkalunoaula389701")
  aula         aula  @relation(fields: [aulaidaula], references: [idaula], onDelete: NoAction, onUpdate: NoAction, map: "fkalunoaula983232")
}

model alunogrupo {
  idalunogrupo Int   @id @default(autoincrement())
  alunoidaluno Int
  grupoidgrupo Int
  grupo        grupo @relation(fields: [grupoidgrupo], references: [idgrupo], onDelete: NoAction, onUpdate: NoAction, map: "fkalunogrupo704827")
  aluno        aluno @relation(fields: [alunoidaluno], references: [idaluno], onDelete: NoAction, onUpdate: NoAction, map: "fkalunogrupo764623")
}

model anuncio {
  idanuncio                           Int                 @id @default(autoincrement())
  valor                               Int
  dataanuncio                         DateTime            @db.Date
  datainicio                          DateTime            @db.Date
  datafim                             DateTime            @db.Date
  quantidade                          Int
  figurinoidfigurino                  Int
  estadoidestado                      Int
  direcaoutilizadoriduser             Int
  encarregadoeducacaoutilizadoriduser Int
  professorutilizadoriduser           Int
  tipotransacao                       String              @default("ALUGUER")
  figurino                            figurino            @relation(fields: [figurinoidfigurino], references: [idfigurino], onDelete: NoAction, onUpdate: NoAction, map: "fkanuncio206012")
  encarregadoeducacao                 encarregadoeducacao @relation(fields: [encarregadoeducacaoutilizadoriduser], references: [utilizadoriduser], onDelete: NoAction, onUpdate: NoAction, map: "fkanuncio342590")
  estado                              estado              @relation(fields: [estadoidestado], references: [idestado], onDelete: NoAction, onUpdate: NoAction, map: "fkanuncio57402")
  direcao                             direcao             @relation(fields: [direcaoutilizadoriduser], references: [utilizadoriduser], onDelete: NoAction, onUpdate: NoAction, map: "fkanuncio631724")
  professor                           professor           @relation(fields: [professorutilizadoriduser], references: [utilizadoriduser], onDelete: NoAction, onUpdate: NoAction, map: "fkanuncio953604")
  transacaofigurino                   transacaofigurino[]
}

model aula {
  idaula                   Int          @id @default(autoincrement())
  pedidodeaulaidpedidoaula Int
  salaidsala               Int
  estadoaulaidestadoaula   Int
  alunoaula                alunoaula[]
  pedidodeaula             pedidodeaula @relation(fields: [pedidodeaulaidpedidoaula], references: [idpedidoaula], onDelete: NoAction, onUpdate: NoAction, map: "fkaula258513")
  estadoaula               estadoaula   @relation(fields: [estadoaulaidestadoaula], references: [idestadoaula], onDelete: NoAction, onUpdate: NoAction, map: "fkaula394641")
  sala                     sala         @relation(fields: [salaidsala], references: [idsala], onDelete: NoAction, onUpdate: NoAction, map: "fkaula645131")
}

model cor {
  idcor    Int        @id @default(autoincrement())
  nomecor  String     @db.VarChar(255)
  figurino figurino[]
}

model direcao {
  utilizadoriduser  Int                 @id
  anuncio           anuncio[]
  evento            evento[]
  utilizador        utilizador          @relation(fields: [utilizadoriduser], references: [iduser], onDelete: NoAction, onUpdate: NoAction, map: "fkdirecao999505")
  figurino          figurino[]
  transacaofigurino transacaofigurino[]
}



model encarregadoeducacao {
  utilizadoriduser  Int                 @id
  aluno             aluno[]
  anuncio           anuncio[]
  utilizador        utilizador          @relation(fields: [utilizadoriduser], references: [iduser], onDelete: NoAction, onUpdate: NoAction, map: "fkencarregad867539")
  figurino          figurino[]
  pedidodeaula      pedidodeaula[]
  transacaofigurino transacaofigurino[]
}

model estado {
  idestado          Int                 @id @default(autoincrement())
  tipoestado        String              @db.VarChar(255)
  anuncio           anuncio[]
  pedidodeaula      pedidodeaula[]
  transacaofigurino transacaofigurino[]
}

model estadoaula {
  idestadoaula   Int    @id @default(autoincrement())
  nomeestadoaula String @db.VarChar(255)
  aula           aula[]
}

model estadosala {
  idestadosala   Int    @id @default(autoincrement())
  nomeestadosala String @db.VarChar(255)
  sala           sala[]
}

model estadouso {
  idestado  Int        @id @default(autoincrement())
  estadouso String     @db.VarChar(255)
  figurino  figurino[]
}

model figurino {
  idfigurino                          Int                 @id @default(autoincrement())
  quantidadedisponivel                Int
  quantidadetotal                     Int
  modelofigurinoidmodelo              Int
  generoidgenero                      Int
  tamanhoidtamanho                    Int
  coridcor                            Int
  estadousoidestado                   Int
  encarregadoeducacaoutilizadoriduser Int?
  direcaoutilizadoriduser             Int?
  professorutilizadoriduser           Int?
  itemfigurinoiditem                  Int?
  anuncio                             anuncio[]
  estadouso                           estadouso           @relation(fields: [estadousoidestado], references: [idestado], onDelete: NoAction, onUpdate: NoAction, map: "fkfigurino733126")
  tamanho                             tamanho             @relation(fields: [tamanhoidtamanho], references: [idtamanho], onDelete: NoAction, onUpdate: NoAction, map: "fkfigurino742941")
  professor                           professor?          @relation(fields: [professorutilizadoriduser], references: [utilizadoriduser], onDelete: NoAction, onUpdate: NoAction, map: "fkfigurino753753")
  cor                                 cor                 @relation(fields: [coridcor], references: [idcor], onDelete: NoAction, onUpdate: NoAction, map: "fkfigurino779940")
  genero                              genero              @relation(fields: [generoidgenero], references: [idgenero], onDelete: NoAction, onUpdate: NoAction, map: "fkfigurino823907")
  direcao                             direcao?            @relation(fields: [direcaoutilizadoriduser], references: [utilizadoriduser], onDelete: NoAction, onUpdate: NoAction, map: "fkfigurino831575")
  encarregadoeducacao                 encarregadoeducacao? @relation(fields: [encarregadoeducacaoutilizadoriduser], references: [utilizadoriduser], onDelete: NoAction, onUpdate: NoAction, map: "fkfigurino857260")
  modelofigurino                      modelofigurino      @relation(fields: [modelofigurinoidmodelo], references: [idmodelo], onDelete: NoAction, onUpdate: NoAction, map: "fkfigurino865766")
  itemfigurino                        itemfigurino?       @relation(fields: [itemfigurinoiditem], references: [iditem], onDelete: NoAction, onUpdate: NoAction, map: "fkfigurino940616")
}

model genero {
  idgenero   Int        @id @default(autoincrement())
  nomegenero String     @db.VarChar(255)
  figurino   figurino[]
}

model grupo {
  idgrupo      Int            @id @default(autoincrement())
  nomegrupo    String         @db.VarChar(255)
  status       String         @default("ABERTA") @db.VarChar(20)
  descricao    String?        @db.VarChar(1000)
  modalidade   String?        @db.VarChar(100)
  nivel        String?        @db.VarChar(50)
  faixaEtaria  String?        @db.VarChar(50)
  professorId  Int?
  estudioId    Int?
  diasSemana   String?        @db.VarChar(50)
  horaInicio   String?        @db.VarChar(5)
  horaFim      String?        @db.VarChar(5)
  duracao      Int?
  lotacaoMaxima Int?
  dataInicio   String?        @db.VarChar(20)
  dataFim      String?        @db.VarChar(20)
  cor          String?        @db.VarChar(20)
  requisitos   String?        @db.VarChar(500)
  alunogrupo   alunogrupo[]
  pedidodeaula pedidodeaula[]
}

model itemfigurino {
  iditem            Int                 @id @default(autoincrement())
  localizacao       String              @db.VarChar(255)
  figurino          figurino[]
  transacaofigurino transacaofigurino[]
}

model modalidade {
  idmodalidade        Int                   @id @default(autoincrement())
  nome                String                @db.VarChar(255)
  modalidadeprofessor modalidadeprofessor[]
}

model modalidadeprofessor {
  idmodalidadeprofessor     Int                      @id @default(autoincrement())
  modalidadeidmodalidade    Int
  professorutilizadoriduser Int
  disponibilidade_mensal    disponibilidade_mensal[]
  modalidade                modalidade               @relation(fields: [modalidadeidmodalidade], references: [idmodalidade], onDelete: NoAction, onUpdate: NoAction, map: "fkmodalidade141851")
  professor                 professor                @relation(fields: [professorutilizadoriduser], references: [utilizadoriduser], onDelete: NoAction, onUpdate: NoAction, map: "fkmodalidade804039")
}

model modelofigurino {
  idmodelo                   Int          @id @default(autoincrement())
  nomemodelo                 String       @db.VarChar(255)
  descricao                  String       @db.VarChar(255)
  fotografia                 String       @db.VarChar(255)
  tipofigurinoidtipofigurino Int
  figurino                   figurino[]
  tipofigurino               tipofigurino @relation(fields: [tipofigurinoidtipofigurino], references: [idtipofigurino], onDelete: NoAction, onUpdate: NoAction, map: "fkmodelofigu271262")
}

model pedidodeaula {
  idpedidoaula                        Int                 @id @default(autoincrement())
  data                                DateTime            @db.Date
  horainicio                          DateTime            @db.Time(6)
  duracaoaula                         DateTime            @db.Time(6)
  maxparticipantes                    Int
  datapedido                          DateTime            @db.Date
  privacidade                         Boolean
  disponibilidade_mensal_id           Int?
  grupoidgrupo                        Int
  estadoidestado                      Int
  salaidsala                          Int
  encarregadoeducacaoutilizadoriduser Int
  novadata                            DateTime?           @db.Date
  novaDataLimite                      DateTime?
  sugestaoestado                      String?
  aula                                aula[]
  encarregadoeducacao                 encarregadoeducacao @relation(fields: [encarregadoeducacaoutilizadoriduser], references: [utilizadoriduser], onDelete: NoAction, onUpdate: NoAction, map: "fkpedidodeau208002")
  disponibilidade_mensal              disponibilidade_mensal? @relation(fields: [disponibilidade_mensal_id], references: [iddisponibilidade_mensal], onDelete: NoAction, onUpdate: NoAction)
  sala                                sala                @relation(fields: [salaidsala], references: [idsala], onDelete: NoAction, onUpdate: NoAction, map: "fkpedidodeau681324")
  estado                              estado              @relation(fields: [estadoidestado], references: [idestado], onDelete: NoAction, onUpdate: NoAction, map: "fkpedidodeau808009")
  grupo                               grupo               @relation(fields: [grupoidgrupo], references: [idgrupo], onDelete: NoAction, onUpdate: NoAction, map: "fkpedidodeau991761")
}

model professor {
  utilizadoriduser        Int                      @id
  anuncio                 anuncio[]
  disponibilidade_mensal  disponibilidade_mensal[]
  figurino                figurino[]
  modalidadeeprofessor    modalidadeprofessor[]
  transacaofigurino       transacaofigurino[]
  utilizador              utilizador               @relation(fields: [utilizadoriduser], references: [iduser], onDelete: NoAction, onUpdate: NoAction, map: "fkprofessor908326")
}

model sala {
  idsala                 Int                      @id @default(autoincrement())
  nomesala               Int
  capacidade             Int
  estadosalaidestadosala Int
  tiposalaidtiposala     Int
  aula                   aula[]
  disponibilidade_mensal disponibilidade_mensal[]
  pedidodeaula           pedidodeaula[]
  tiposala               tiposala                 @relation(fields: [tiposalaidtiposala], references: [idtiposala], onDelete: NoAction, onUpdate: NoAction, map: "fksala356279")
  estadosala             estadosala               @relation(fields: [estadosalaidestadosala], references: [idestadosala], onDelete: NoAction, onUpdate: NoAction, map: "fksala483672")
}

model tamanho {
  idtamanho   Int        @id @default(autoincrement())
  nometamanho String     @db.VarChar(255)
  figurino    figurino[]
}


model tipofigurino {
  idtipofigurino Int              @id @default(autoincrement())
  tipofigurino   String           @db.VarChar(255)
  modelofigurino modelofigurino[]
}

model tiposala {
  idtiposala   Int    @id @default(autoincrement())
  nometiposala String @db.VarChar(255)
  sala         sala[]
}

model transacaofigurino {
  idtransacao                         Int                  @id @default(autoincrement())
  quantidade                          Int
  datatransacao                       DateTime             @db.Date
  anuncioidanuncio                    Int
  estadoidestado                      Int
  itemfigurinoiditem                  Int
  direcaoutilizadoriduser             Int?
  encarregadoeducacaoutilizadoriduser Int?
  professorutilizadoriduser           Int?
  anuncio                             anuncio              @relation(fields: [anuncioidanuncio], references: [idanuncio], onDelete: NoAction, onUpdate: NoAction, map: "fktransacaof244520")
  itemfigurino                        itemfigurino         @relation(fields: [itemfigurinoiditem], references: [iditem], onDelete: NoAction, onUpdate: NoAction, map: "fktransacaof401607")
  direcao                             direcao?             @relation(fields: [direcaoutilizadoriduser], references: [utilizadoriduser], onDelete: NoAction, onUpdate: NoAction, map: "fktransacaof510648")
  encarregadoeducacao                 encarregadoeducacao? @relation(fields: [encarregadoeducacaoutilizadoriduser], references: [utilizadoriduser], onDelete: NoAction, onUpdate: NoAction, map: "fktransacaofencarregado")
  professor                           professor?           @relation(fields: [professorutilizadoriduser], references: [utilizadoriduser], onDelete: NoAction, onUpdate: NoAction, map: "fktransacaofprofessor")
  estado                              estado               @relation(fields: [estadoidestado], references: [idestado], onDelete: NoAction, onUpdate: NoAction, map: "fktransacaof915028")
}

model utilizador {
  iduser              Int                  @id @default(autoincrement())
  nome                String               @db.VarChar(255)
  email               String               @unique @db.VarChar(255)
  telemovel           String?              @db.VarChar(20)
  password            String               @db.VarChar(255)
  estado              Boolean              @default(true)
  role                String               @default("utilizador")
  aluno               aluno[]
  direcao             direcao?
  encarregadoeducacao encarregadoeducacao?
  professor           professor?
  notificacao         notificacao[]
}

model notificacao {
  idnotificacao       Int         @id @default(autoincrement())
  mensagem            String      @db.VarChar(500)
  tipo                String      @db.VarChar(50)
  lida                Boolean     @default(false)
  dataleitura         DateTime?
  datanotificacao     DateTime    @default(now())
  utilizadoriduser    Int
  utilizador          utilizador  @relation(fields: [utilizadoriduser], references: [iduser])
}

model disponibilidade_mensal {
  iddisponibilidade_mensal                  Int                 @id @default(autoincrement())
  professorutilizadoriduser                 Int
  modalidadesprofessoridmodalidadeprofessor Int
  data                                      DateTime            @db.Date
  horainicio                                DateTime            @db.Time(6)
  horafim                                   DateTime            @db.Time(6)
  ativo                                     Boolean             @default(true)
  salaid                                    Int?
  minutos_ocupados                          Int                 @default(0)
  pedidodeaula                              pedidodeaula[]
  professor                                 professor           @relation(fields: [professorutilizadoriduser], references: [utilizadoriduser], onDelete: NoAction, onUpdate: NoAction)
  modalidadeprofessor                       modalidadeprofessor @relation(fields: [modalidadesprofessoridmodalidadeprofessor], references: [idmodalidadeprofessor], onDelete: NoAction, onUpdate: NoAction)
  sala                                      sala?               @relation(fields: [salaid], references: [idsala], onDelete: NoAction, onUpdate: NoAction)
}

model evento {
  idevento                    Int      @id @default(autoincrement())
  titulo                      String   @db.VarChar(255)
  descricao                   String?  @db.Text
  dataevento                  DateTime @db.Date
  localizacao                 String?  @db.VarChar(255)
  imagem                      String?  @db.VarChar(500)
  linkbilhetes                String?  @db.VarChar(500)
  publicado                   Boolean  @default(false)
  destaque                    Boolean  @default(false)
  datacriacao                 DateTime @default(now())
  direcaoutilizadoriduser     Int?
  direcao                     direcao? @relation(fields: [direcaoutilizadoriduser], references: [utilizadoriduser], onDelete: NoAction, onUpdate: NoAction)
}
