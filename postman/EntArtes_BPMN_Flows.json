{
  "info": {
    "name": "EntArtes — Fluxos BPMN",
    "description": "Coleção Postman com os 4 fluxos BPMN completos da Escola de Dança Ent'Artes.\n\nPré-requisitos:\n1. Backend em http://localhost:3000\n2. Seed SQL executado (backend/prisma/seed_completa.sql)\n3. Base de dados PostgreSQL com dados de teste\n\nFluxos:\n- BPMN 1: Pedido de Aula (EE → Direção)\n- BPMN 2: Remarcação de Aula (Direção → Professor → EE)\n- BPMN 3: Aluguer de Figurino (EE → Direção)\n- BPMN 4: Criar Anúncio (EE → Direção)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "BPMN 1 — Pedido de Aula",
      "description": "Fluxo: Encarregado consulta disponibilidades → submete pedido → Direção aprova → aula CONFIRMADA",
      "item": [
        {
          "name": "1.1 Login Encarregado",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login OK', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.token).to.not.be.empty;",
                  "  pm.environment.set('token_encarregado', json.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email_encarregado}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "1.2 Consultar Disponibilidades",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Disponibilidades OK', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data).to.be.an('array');",
                  "  if (json.data.length > 0) {",
                  "    const hoje = new Date().toISOString().split('T')[0];",
                  "    const futuro = json.data.find(s => s.data > hoje && s.maxDuracao > 0) || json.data[0];",
                  "    pm.environment.set('slot_id', futuro.id);",
                  "    pm.environment.set('slot_data', futuro.data);",
                  "    pm.environment.set('slot_maxDuracao', String(futuro.maxDuracao || 60));",
                  "    pm.environment.set('slot_professorId', futuro.professorId || '');",
                  "    pm.environment.set('slot_estudioId', futuro.estudioId || '1');",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/public/disponibilidades",
              "host": ["{{base_url}}"],
              "path": ["api", "public", "disponibilidades"]
            }
          }
        },
        {
          "name": "1.3 Criar Pedido de Aula",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Pedido criado', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  const id = json.data?.idpedidoaula || json.data?.[0]?.idpedidoaula || json.data?.id || '';",
                  "  pm.expect(id).to.not.be.empty;",
                  "  pm.environment.set('pedido_id', String(id));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_encarregado}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": \"{{slot_data}}\",\n  \"horainicio\": \"10:00\",\n  \"duracaoaula\": {{slot_maxDuracao}},\n  \"disponibilidade_mensal_id\": {{slot_id}},\n  \"salaidsala\": {{slot_estudioId}},\n  \"privacidade\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/encarregado/aulas",
              "host": ["{{base_url}}"],
              "path": ["api", "encarregado", "aulas"]
            }
          }
