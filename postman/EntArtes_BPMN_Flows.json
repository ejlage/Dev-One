                "exec": [
                  "pm.test('Pedidos pendentes listados', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data).to.be.an('array');",
                  "  const pendentes = json.data.filter(a => a.status === 'Pendente' || a.status === 'PENDENTE');",
                  "  if (pendentes.length > 0) {",
                  "    pm.environment.set('pedido_id', pendentes[0].id);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_direcao}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/direcao/aulas/pending",
              "host": ["{{base_url}}"],
              "path": ["api", "direcao", "aulas", "pending"]
            }
          }
        },
        {
          "name": "1.6 Aprovar Pedido de Aula",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Pedido aprovado', () => {",
