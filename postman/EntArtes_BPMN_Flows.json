              "mode": "raw",
              "raw": "{\n  \"salaId\": {{sala_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/direcao/aulas/{{pedido_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["api", "direcao", "aulas", "{{pedido_id}}", "approve"]
            }
          }
        },
        {
          "name": "1.7 Verificar Aulas (todas)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Aulas listadas', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data).to.be.an('array');",
                  "  const confirmada = json.data.find(a => a.id === pm.environment.get('pedido_id'));",
                  "  if (confirmada) {",
                  "    pm.expect(['CONFIRMADA', 'Confirmada', 'Confirmado']).to.include(confirmada.status);",
                  "  }",
                  "  console.log('Total de aulas:', json.data.length);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_direcao}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/aulas/all",
              "host": ["{{base_url}}"],
              "path": ["api", "aulas", "all"]
            }
          }
        }
      ]
